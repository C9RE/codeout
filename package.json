{
	"name": "codeoutcli",
	"version": "1.3.0",
	"type": "module",
	"description": "Self-hosted GUI for your AI coding agents. Run Claude or a shell on your own machine and drive it from your phone or browser, end-to-end encrypted.",
	"license": "MIT",
	"bin": {
		"codeout": "./cli.js"
	},
	"scripts": {
