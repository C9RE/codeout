		"libsodium-wrappers": "^0.8.4",
		"@homebridge/node-pty-prebuilt-multiarch": "^0.13.0",
		"qrcode": "^1.5.4",
		"qrcode-terminal": "^0.12.0",
		"ws": "^8.21.0"
	},
	"trustedDependencies": ["@homebridge/node-pty-prebuilt-multiarch"],
	"files": [
		"cli.js",
		"server.js",
		"build-webui.mjs",
		"sessions.js",
		"archive.js",
		"crypto.js",
		"auth.js",
		"pty-bridge.js",
		"chat-events.js",
		"claude-chat.js",
		"codex-chat.js",
		"gemini-chat.js",
		"json-rpc.js",
		"agents.js",
		"apns.js",
		"platform/",
